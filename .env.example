# ========================================
# CREDENCIALES DE GOOGLE CLOUD (SERVICE ACCOUNT)
# ========================================

# Correo del Service Account extraído del JSON descargado de Google Cloud Console.
# Ejemplo: mi-bot@mi-proyecto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL="tu-cuenta-de-servicio@tu-proyecto.iam.gserviceaccount.com"

# ⚠️  IMPORTANTE: La private key debe ir ENTRE COMILLAS DOBLES
# y los saltos de línea deben ser \n LITERALES (la secuencia barra-n), no saltos reales de teclado.
#
# ✅ Correcto: "-----BEGIN PRIVATE KEY-----\nMIIEvg...\n-----END PRIVATE KEY-----\n"
# ❌ Incorrecto: copiar/pegar el bloque con ENTER reales (rompe el parser de dotenv)
#
# Tip: Copia el valor de "private_key" del JSON tal cual, incluyendo los \n que ya trae.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIB...RESTO_DE_LA_LLAVE...\n-----END PRIVATE KEY-----\n"

# ========================================
# CONFIGURACIÓN DE GOOGLE SHEETS
# ========================================

# El ID se encuentra en la URL de tu Google Sheet:
# https://docs.google.com/spreadsheets/d/AQUI_ESTA_EL_ID/edit
GOOGLE_SHEET_ID="tu_id_de_hoja_aqui"

# ========================================
# SEGURIDAD (WHATSAPP AUTH STATE - AES-256)
# ========================================

# Clave maestra para encriptar la sesión de WhatsApp.
# ¡Debe ser la MISMA clave siempre (local y en GitHub Secrets)!
# Si la cambias, tendrás que correr npm run setup nuevamente.
# Recomendación: usa una cadena de al menos 32 caracteres alfanuméricos.
AUTH_ENCRYPTION_KEY="cambia_esto_por_una_clave_secreta_de_al_menos_32_caracteres"

# ========================================
# OPCIONES DE PRUEBA (Opcional)
# ========================================

# Descomenta la línea de abajo para que npm run test:sheet también pruebe la escritura en el Sheet.
# TEST_WRITE=true
